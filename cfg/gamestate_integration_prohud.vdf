"gamestate_integration_prohud"
{
	"uri" "http://localhost:3000/"
	"timeout" "5.0"
	"buffer" "0.1"
	"throttle" "0.1"
	"heartbeat" "30.0"
	"auth"
	{
		"token" ""
	}
	"data"
	{
		"provider" "1"
		"map" "1"
		"round" "1"
		"player_id" "1"
		"player_state" "1"
		"player_weapons" "1"
		"player_match_stats" "1"
		"allplayers_id" "1"
		"allplayers_state" "1"
		"allplayers_weapons" "1"
		"allplayers_match_stats" "1"
		"allplayers_position" "1"
		"phase_countdowns" "1"
		"bomb" "1"
	}
}
